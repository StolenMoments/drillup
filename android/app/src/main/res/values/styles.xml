<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.Drillup" parent="android:style/Theme.Material.Light.NoActionBar">
        <item name="android:fontFamily">sans</item>
        <item name="android:windowActionModeOverlay">true</item>
        <item name="android:windowBackground">@color/shell_background</item>
        <item name="android:navigationBarColor">@color/shell_background</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowLightNavigationBar">true</item>
    </style>

    <style name="Theme.Drillup.Starting" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/shell_background</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/splash_icon</item>
        <item name="postSplashScreenTheme">@style/Theme.Drillup</item>
    </style>
</resources>
